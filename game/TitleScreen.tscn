[sub_resource type="GDScript" id="GDScript_6e2l2"]
script/source = "extends AnimatedSprite2D

const RETRO_FPS: float = 2
var time_since_last_frame: float = 0.0
var stepped_modulate: Color

var is_first_frame: bool = true

func _ready() -> void:
	stepped_modulate = modulate

func _process(delta: float) -> void:
	time_since_last_frame += delta
	var frame_duration = 1.0 / RETRO_FPS
	if is_first_frame:
		stepped_modulate = modulate
		is_first_frame = false
		return

	if time_since_last_frame >= frame_duration:
		stepped_modulate = modulate
		time_since_last_frame = fmod(time_since_last_frame, frame_duration)
	else:
		modulate = stepped_modulate
"

[sub_resource type="CanvasItemMaterial" id="CanvasItemMaterial_la86q"]

[sub_resource type="GDScript" id="GDScript_m1n6c"]
script/source = "extends Sprite2D

const RETRO_FPS: float = 3.0
var time_since_last_frame: float = 0.0

var stepped_modulate: Color

func _ready() -> void:
	# Start completely invisible to match the animation beginning
	modulate.a = 0.0
	stepped_modulate = modulate

func _process(delta: float) -> void:
	time_since_last_frame += delta
	var frame_duration = 1.0 / RETRO_FPS
	
	if time_since_last_frame >= frame_duration:
		# 1. Grab the smooth value from self_modulate (driven by AnimationPlayer)
		stepped_modulate = self_modulate
		time_since_last_frame = fmod(time_since_last_frame, frame_duration)
	else:
		# 2. Force the actual visibility to stay locked to our choppy step
		modulate = stepped_modulate
		
		# 3. Clear self_modulate to full white so it doesn't double-multiply the fade
		self_modulate = Color.WHITE
"

