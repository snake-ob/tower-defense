[sub_resource type="GDScript" id="GDScript_la86q"]
script/source = "extends Button

func _ready():
	if not button_up.is_connected(_on_button_pressed):
		button_up.connect(_on_button_pressed)

func _on_button_pressed():
	LevelState.current_level = 0
	var level_load : PackedScene = load(\"res://assets/splash-screens/LevelLoad.tscn\")
	SceneLoader._next_scene(level_load)

func _on_timeout():
	pass
"

