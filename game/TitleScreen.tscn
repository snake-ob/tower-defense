[sub_resource type="GDScript" id="GDScript_qtfsa"]
script/source = "extends Node2D

const RETRO_FPS: float = 12.0
var time_since_last_frame: float = 0.0

# Dictionary to store the frozen states for every child
var stepped_transforms: Dictionary = {}

func _ready() -> void:
	# Save the starting state of every single child node
	for child in get_children():
		if child is CanvasItem and not child is AnimationPlayer:
			_save_child_state(child)

func _process(delta: float) -> void:
	time_since_last_frame += delta
	var frame_duration = 1.0 / RETRO_FPS
	
	if time_since_last_frame >= frame_duration:
		for child in get_children():
			if child is CanvasItem and not child is AnimationPlayer:
				_save_child_state(child)
				
		time_since_last_frame = fmod(time_since_last_frame, frame_duration)
	else:
		for child in get_children():
			if child is CanvasItem and not child is AnimationPlayer and stepped_transforms.has(child):
				var state = stepped_transforms[child]
				child.position = state[\"pos\"]
				child.rotation = state[\"rot\"]
				child.scale = state[\"scale\"]
				child.modulate = state[\"mod\"]

func _save_child_state(child: CanvasItem) -> void:
	stepped_transforms[child] = {
		\"pos\": child.position,
		\"rot\": child.rotation,
		\"scale\": child.scale,
		\"mod\": child.modulate # <─── Caches the transparency value
	}
"

