[sub_resource type="GDScript" id="GDScript_tu3e0"]
script/source = "extends Node2D

var title_path = \"res://game/TitleScreen.tscn\"
var scene_timer: Timer
var time: float = 5.0

func _ready():
	Engine.time_scale = 1.0
	scene_timer = Timer.new()
	scene_timer.one_shot = true
	scene_timer.timeout.connect(_scene_timeout)
	add_child(scene_timer)
	scene_timer.start(5.0)
	
	LevelState.current_level = 0

func _scene_timeout():
	var title_scene = load(title_path)
	SceneLoader._next_scene(title_scene)
"

