[sub_resource type="GDScript" id="GDScript_wiylm"]
resource_name = "stretch.gd"
script/source = "extends State

var sprite: AnimatedSprite2D
var animanager: AniManager
var sm: StateMachine

func _setup(_ref):
	sprite = _ref.sprite
	animanager = _ref.animanager
	sm = _ref.state_machine
	actor = _ref.actor

func _enter_state():
	actor.velocity = Vector2.ZERO
	animanager.custom_override = true
	animanager.play_anim('stretch')
	if not sprite.animation_finished.is_connected(_anim_finished):
		sprite.animation_finished.connect(_anim_finished)

func _exit_state():

	animanager.custom_override = false
	if sprite.animation_finished.is_connected(_anim_finished):
		sprite.animation_finished.disconnect(_anim_finished)
	
func _anim_finished():
	if not 'stretch' in sprite.animation:
		print(\"Error: Stretch not found\")
		return
	if sm.has_state('Smash'):
		change_state.emit('Smash')
"

[sub_resource type="GDScript" id="GDScript_5feut"]
resource_name = "smash.gd"
script/source = "extends State

var animanager: AniManager
var sprite: AnimatedSprite2D
var wall_buster: WallBuster

func _setup(_ref):
	animanager = _ref.animanager
	sprite = _ref.sprite
	wall_buster = _ref.wall_buster
	
func _enter_state():
	animanager.custom_override = true
	animanager.play_anim('smash')
	if not sprite.animation_finished.is_connected(_anim_finished):
		sprite.animation_finished.connect(_anim_finished)
	wall_buster.monitoring = true

func _exit_state():
	animanager.custom_override = false
	if sprite.animation_finished.is_connected(_anim_finished):
		sprite.animation_finished.disconnect(_anim_finished)
	wall_buster.monitoring = false
		
func _anim_finished():
	if not 'smash' in sprite.animation.to_lower():
		return
	change_state.emit('Reset')
"

