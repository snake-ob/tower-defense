[sub_resource type="GDScript" id="GDScript_a23sr"]
resource_name = "Chase"
script/source = "extends State

var bullet_spawner = null
	
func _setup(p_ref):
	ref = p_ref
	actor = ref.actor
	if ref.has('bullet_spawner'):
		bullet_spawner = ref.bullet_spawner
	
func _enter_state():
	if bullet_spawner:
		bullet_spawner.activate()
	
func _exit_state():
	if bullet_spawner:
		bullet_spawner.deactivate()

func _physics_update(delta):
	if ref.active_targets:
		var target = ref.active_targets[0]
		var target_pos = target.global_position
		var actor_pos = actor.global_position
		
		var direction = actor_pos.direction_to(target_pos)
		var target_velocity = direction * ref.move.speed		
		actor.velocity = actor.velocity.move_toward(target_velocity, ref.move.acceleration * delta)
	else:
		change_state.emit('reset')
"

[sub_resource type="GDScript" id="GDScript_im3kb"]
script/source = "extends State

var centre_pos = Vector2(515, 320)

func _setup(p_ref):
	ref = p_ref
	actor = ref.actor

func _physics_update(delta):
	if ref.active_targets:
		change_state.emit('chase')

	var actor_pos = actor.global_position
		
	var direction = actor_pos.direction_to(centre_pos)
	var target_velocity = direction * ref.move.speed		
	actor.velocity = actor.velocity.move_toward(target_velocity, ref.move.acceleration * delta)
"

