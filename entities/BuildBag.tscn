[sub_resource type="GDScript" id="GDScript_7hq8g"]
script/source = "extends Node2D
class_name BuildBag

func _ready():
	for child in get_children():
		if child.has_signal('clicked'):
			child.clicked.connect(_on_clicked)

func trigger_edit_mode():
	print(\"Mouse mode\")
	if MouseMode.current != \"build_fence\":
		MouseMode.current = \"build_fence\"
	else:
		MouseMode.current = \"\"

func _on_clicked(p_node):
	trigger_edit_mode()
"

[sub_resource type="GDScript" id="GDScript_bpuxm"]
resource_name = "click_area.gd"
script/source = "extends Area2D

signal clicked(caller)

func _input_event(viewport: Viewport, event: InputEvent, shape_idx: int):
	if event is InputEventMouseButton and event.pressed and event.button_index == MOUSE_BUTTON_LEFT:
		clicked.emit(self)
"

