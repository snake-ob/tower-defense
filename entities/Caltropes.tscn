[sub_resource type="GDScript" id="GDScript_ti15s"]
script/source = "extends State

var physics: Node
var detect_zone: Area2D
var collisions: Array

func _enter_state():
	for collision in collisions:
		collision.disabled = true # To disable bizarre physics when they all spawn on top of each other
	
	await get_tree().create_timer(0.2).timeout
	
	for collision in collisions:
		collision.disabled = false

func _setup(p_ref):
	physics = p_ref.physics
	detect_zone = p_ref.detect_zone
	collisions = p_ref.collisions

func _physics_update(delta):
	physics._process_friction(delta)

func _on_detect_zone_body_entered(body: Node2D) -> void:
	if 'slowed_down' in body:
		body.slowed_down = true

func _on_detect_zone_body_exited(body: Node2D) -> void:
	if 'slowed_down' in body:
		body.slowed_down = false
"

