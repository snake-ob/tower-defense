[sub_resource type="GDScript" id="GDScript_a23sr"]
resource_name = "Chase"
script/source = "extends State

func _enter_state():
	pass
	
func _setup(p_ref):
	ref = p_ref
	actor = ref.actor

func _physics_update(delta):
	if ref.target:
		var target_pos = ref.target.global_position
		var actor_pos = actor.global_position
		
		var direction = actor_pos.direction_to(target_pos)
		var target_velocity = direction * actor.move.speed
		print(actor.velocity)
		
		actor.velocity = actor.velocity.move_toward(target_velocity, actor.move.acceleration * delta)
"

