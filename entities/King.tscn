[sub_resource type="GDScript" id="GDScript_5x2kh"]
script/source = "extends State

var pickup: Area2D
var soft_collision: Area2D

func _setup(p_ref):
	pickup = p_ref.pickup
	soft_collision = p_ref.soft_collision

func _update(delta):
	if pickup.picked_up:
		change_state.emit('picked')

func _enter_state():
	soft_collision.enable()
"

[sub_resource type="GDScript" id="GDScript_ahdhg"]
script/source = "extends State

var pickup: Area2D
var soft_collision

func _setup(p_ref):
	soft_collision = p_ref.soft_collision
	pickup = p_ref.pickup

func _update(delta):
	if not pickup.picked_up:
		change_state.emit('idle')

func _enter_state():
	soft_collision.disable()

func exit_state():
	soft_collision.enable()
"

