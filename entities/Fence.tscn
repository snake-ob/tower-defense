[sub_resource type="GDScript" id="GDScript_23x7k"]
script/source = "extends TileMapLayer

@onready var preview_layer: TileMapLayer = $PreviewLayer

var first_post_coords: Vector2i = Vector2i(-1, -1)
var is_placing_second: bool = false

var last_hover_cell: Vector2i = Vector2i(-1, -1)

var terrain_set_id: int = 0
var terrain_id: int = 0

func _ready():
	GlobalClick.build_click.connect(_on_build)
	GlobalClick.build_cancel.connect(_on_cancel)

func _on_build():
	var clicked_cell = local_to_map(get_local_mouse_position())
	
	if not is_placing_second:
		first_post_coords = clicked_cell
		is_placing_second = true
		last_hover_cell = Vector2i(-1, -1)
	else:
		build_fence_terrain(first_post_coords, clicked_cell)
		is_placing_second = false
		preview_layer.clear()
		last_hover_cell = Vector2i(-1, -1)
		SignalBus.wall_built.emit()
	
func _on_cancel():
	Inventory.items.walls.current += 1
	first_post_coords = Vector2i(-1, -1)
	is_placing_second=  false
	last_hover_cell = Vector2i(-1, -1)
	preview_layer.clear()
	
	SignalBus.wall_cancelled.emit()
	SignalBus.inv_updated.emit()
	
func _process(_delta):
	if not MouseMode.current == \"build_fence\":
		return

	var hover_cell = local_to_map(get_local_mouse_position())
	
	if hover_cell != last_hover_cell:
		last_hover_cell = hover_cell
		
		if not is_placing_second:
			preview_single_cell(hover_cell)
		else:
			update_preview(first_post_coords, hover_cell)

func preview_single_cell(cell: Vector2i):
	preview_layer.clear()
	var single_cell_array: Array[Vector2i] = [cell]
	preview_layer.set_cells_terrain_connect(single_cell_array, terrain_set_id, terrain_id, true)

func update_preview(start: Vector2i, end: Vector2i):
	preview_layer.clear()
	
	var is_straight_line = (start.x == end.x) or (start.y == end.y)
	
	if is_straight_line:
		var cells_to_preview = get_line_cells(start, end)
		preview_layer.set_cells_terrain_connect(cells_to_preview, terrain_set_id, terrain_id, true)
	else:
		var independent_cells: Array[Vector2i] = [start, end]
		preview_layer.set_cells_terrain_connect(independent_cells, terrain_set_id, terrain_id, true)

func build_fence_terrain(start: Vector2i, end: Vector2i):
	if start.x != end.x and start.y != end.y:
		return
		
	var cells_to_paint = get_line_cells(start, end)
	set_cells_terrain_connect(cells_to_paint, terrain_set_id, terrain_id, true)
	MouseMode.reset()

func get_line_cells(start: Vector2i, end: Vector2i) -> Array[Vector2i]:
	var cells: Array[Vector2i] = []
	var dir_x = sign(end.x - start.x)
	var dir_y = sign(end.y - start.y)                  
	
	if dir_x == 0 and dir_y == 0:
		cells.append(start)
		return cells
		
	var current = start
	while current != end + Vector2i(dir_x, dir_y):
		cells.append(current)
		current.x += dir_x
		current.y += dir_y
		
	return cells

func break_wall_tile(cell_pos: Vector2i):
	var broken_id = 1
	set_cells_terrain_connect([cell_pos], 0, broken_id, false)
"

[sub_resource type="GDScript" id="GDScript_wiylm"]
script/source = "extends Node

@export var mouse_mode: bool = false:
	set(val):
		if val == true:
			MouseMode.current = 'build_fence'
		else:
			MouseMode.current = ''
"

