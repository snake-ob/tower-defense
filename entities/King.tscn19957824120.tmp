script/source = "extends State

var pickup: Area2D

func _setup(p_ref):
	pass

func _update(delta):
	if pickup.picked_up:
		change_state.emit('picked')
"

[sub_resource type="GDScript" id="GDScript_01d4n"]
script/source = "extends State

var pickup: Area2D
var physics: Node


func _setup(p_ref):
	pickup = p_ref.pickup
	physics = p_ref.physics
	
func _enter_state():
	pickup.picked_up = false
	
func _update(delta):
	if physics.horizontal_velocity == 0:
		change_state.emit('idle')
"

[sub_resource type="GDScript" id="GDScript_ahdhg"]
script/source = "extends State

var pickup: Area2D
var soft_collision

func _setup(p_ref):
	soft_collision = p_ref.soft_collision

func _update(delta):
	if pickup.thrown:
		change_state.emit('thrown')

func _enter_state():
	soft_collision.disable()
	print(\"Picked up\")

func exit_state():
	soft_collision.enable()
"

