[sub_resource type="GDScript" id="GDScript_oqlok"]
script/source = "extends Node2D

@onready var ref: Ref = $Ref
var gameover_path: String = \"res://assets/splash-screens/GameOver.tscn\"

var world_timer: Timer

func _ready() -> void:
	SignalBus.spawn_bullet.connect(_spawn_bullet)
	SignalBus.request_closest_exit.connect(_return_closest_exit)
	$LevelRoot/EscapeZone.king_taken.connect(_on_king_taken)
	_setup_ref()
	_setup_nodes(self)
	if SceneLoader.current_scene == null:
		SceneLoader.current_scene = self
	
	world_timer = Timer.new()
	world_timer.one_shot = true
	world_timer.timeout.connect(_world_timeout)
	
func _setup_ref():
	ref.set('level', self)
	ref.set('spawners', $Systems/Spawners)
	ref.set('enemies', $EntityRoot/Enemies)
	ref.set('entity_root', $EntityRoot)
	ref.set('spawn_path', $LevelRoot/SpawnPath)
	ref.set('player', $EntityRoot/Player)
	ref.set('centre', $LevelRoot/Centre.global_position)
	ref.set(\"towers\", $EntityRoot/Towers)
	ref.set('tower_spawns', $LevelRoot/TowerSpawns)
	ref.set('wave_manager', $Systems/WaveManager)
	ref.set('time_left', $HUDLayer/TimeLeft)
	ref.set('projectiles', $EntityRoot/Projectiles)
	ref.set('status_label', $HUDLayer/Status)
	ref.set('item_ui', $HUDLayer/InvItem)
	ref.set('inv_manager', $Systems/InventoryManager)
	
	for spawner in ref.spawners.get_children():
		spawner.centre = ref.centre

func _setup_nodes(p_node):
	for node in p_node.get_children():
		if node.has_method('_setup_lvl'):
			node._setup_lvl(ref)
		if node.get_child_count() > 0:
			_setup_nodes(node)

func _spawn_bullet(p_bullet):
	ref.projectiles.add_child(p_bullet)

func _return_closest_exit(p_node):
	var closest_pos = ref.spawn_path.get_closest_position(p_node)
	p_node.catch_exit_pos(closest_pos)
	
func _on_king_taken():
	var roots = [$LevelRoot, $EntityRoot, $Systems]
	Engine.time_scale = 0.2
	var slow_timer = Timer.new()
	slow_timer.one_shot = true
	slow_timer.timeout.connect(_on_slow_timeout)
	add_child(slow_timer)
	slow_timer.start(0.5)
	SignalBus.gameover.emit()
	$HUDLayer/BlackFade.fading = true
	$Camera/Camera2D.zoom_all_the_way_out(1.0)


func _on_slow_timeout():
	var gameover = load(gameover_path)
	SceneLoader._next_scene(gameover)
	
func _world_timeout():
	# King drops blueprints
	# Goblins run to forest
	# Portal opens?
	pass
"

