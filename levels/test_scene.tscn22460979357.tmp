[sub_resource type="GDScript" id="GDScript_4qj7r"]
script/source = "#active.gd
extends State

var bullet_spawner: Node
var pickup: Node

func _setup(p_ref: Ref):
	bullet_spawner = p_ref.bullet_spawner
	pickup = p_ref.pickup

func _enter_state():
	bullet_spawner.activate()

func _exit_state():
	bullet_spawner.deactivate()

func _update(delta):
	if pickup.picked_up:
		change_state.emit('grabbed')
"

[sub_resource type="GDScript" id="GDScript_mttso"]
script/source = "#deactive.gd
extends State

var bullet_spawner: Node

func _setup(p_ref: Ref):
	bullet_spawner = p_ref.bullet_spawner
	
func _enter_state():
	bullet_spawner.deactivate()
"

[sub_resource type="GDScript" id="GDScript_vcivv"]
script/source = "#grabbed.gd
extends State

var bullet_spawner: Node
var pickup: Area2D
var saved_collision_layer: int

func _setup(p_ref: Ref):
	bullet_spawner = p_ref.bullet_spawner
	actor = p_ref.actor
	pickup = p_ref.pickup

func _enter_state():
	bullet_spawner.deactivate()
	saved_collision_layer = actor.collision_layer
	actor.collision_layer = 0

func _exit_state():
	actor.collision_layer = saved_collision_layer

func _update(delta):
	if not pickup.picked_up:
		change_state.emit('active')
"

